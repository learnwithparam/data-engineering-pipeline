# ============================================================================
# Database (warehouse Postgres)
# ============================================================================
DB_POSTGRES=postgresql://warehouse:warehouse_pw@postgres:5432/warehouse
DB_MYSQL=mysql://source:source_pw@mysql:3306/source
DB_COMMAND_TIMEOUT_SECONDS=30

# ============================================================================
# MinIO (S3-compatible object store)
# ============================================================================
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio_secret_2024
MINIO_BUCKET_RAW=raw-data
MINIO_BUCKET_PROCESSED=processed-data
MINIO_MAX_UPLOAD_RETRIES=2

# ============================================================================
# Airflow
# ============================================================================
AIRFLOW_BASE_URL=http://airflow-webserver:8080
AIRFLOW_USERNAME=airflow
AIRFLOW_PASSWORD=airflow
AIRFLOW_BATCH_DAG_ID=batch_ingestion_dag
AIRFLOW_WAREHOUSE_DAG_ID=warehouse_transform_dag
AIRFLOW_REQUEST_TIMEOUT_SECONDS=30

# ============================================================================
# Great Expectations
# ============================================================================
GE_CLI_PATH=/app/.venv/bin/great_expectations
GE_TIMEOUT_SECONDS=300

# ============================================================================
# API server
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
